{
  "name": "@abc/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @abc/shared build && pnpm --filter @abc/db build && nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "push:generate-keys": "web-push generate-vapid-keys",
    "seed:admin": "dotenv -e ../../.env -- tsx src/scripts/seed-admin.ts",
    "seed:mock": "dotenv -e ../../.env -- tsx src/scripts/seed-mock-data.ts"
  },
  "dependencies": {
    "@abc/db": "workspace:*",
    "@abc/shared": "workspace:*",
    "@nestjs/common": "11.1.24",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.24",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.24",
    "@nestjs/swagger": "11.4.4",
    "@supabase/supabase-js": "2.106.2",
    "argon2": "0.44.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "cookie-parser": "1.4.7",
    "exceljs": "4.4.0",
    "express": "5.2.1",
    "multer": "2.1.1",
    "playwright": "1.60.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "sanitize-html": "2.17.4",
    "web-push": "3.6.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.21",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.9.1",
    "@types/sanitize-html": "2.16.1",
    "@types/web-push": "3.6.4",
    "dotenv-cli": "11.0.0",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
